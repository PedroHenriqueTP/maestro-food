# =======================================================
# MAESTRO OS - VARIÁVEIS DE AMBIENTE (TEMPLATE)
# Copie este arquivo para .env e preencha os valores reais
# =======================================================

# -------------------------------------------------------
# 1. NODE ENVIRONMENT
# -------------------------------------------------------
NODE_ENV=development
PORT=3001

# -------------------------------------------------------
# 2. BANCO DE DADOS (PostgreSQL + Supabase)
# -------------------------------------------------------
# ATENÇÃO: Para o Row-Level Security (RLS) funcionar corretamente,
# NÃO utilize a string de conexão do superuser 'postgres' em produção.
# Crie um role específico para a aplicação.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/maestro?schema=public"

# -------------------------------------------------------
# 3. REDIS (Cache & Filas)
# -------------------------------------------------------
REDIS_URL="redis://localhost:6379"

# -------------------------------------------------------
# 4. N8N (Orquestração de Automação)
# -------------------------------------------------------
N8N_WEBHOOK_URL="http://localhost:5678/webhook"

# -------------------------------------------------------
# 5. QDRANT (Memória Vetorial & Inteligência)
# -------------------------------------------------------
QDRANT_URL="http://localhost:6333"

# -------------------------------------------------------
# 6. SEGURANÇA E AUTENTICAÇÃO (Supabase Auth / NextAuth)
# -------------------------------------------------------
JWT_SECRET="seu_jwt_secret_super_seguro_aqui_gerado_aleatoriamente"
NEXT_PUBLIC_SUPABASE_URL="sua_url_do_supabase"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sua_anon_key_do_supabase"

# -------------------------------------------------------
# 7. MAESTRO FRONTEND (CORS)
# -------------------------------------------------------
FRONTEND_ORIGIN="http://localhost:3000"
